              "raw": "{\n  \"type\": \"expense\",\n  \"category\": \"Food\",\n  \"amount\": 45.99,\n  \"date\": \"2026-05-01T19:17:51.083Z\",\n  \"description\": \"Lunch at cafe\"\n}"
